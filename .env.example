# App
APP_ENV=development
APP_PORT=8070

# Supabase (producción — dejar en blanco para desarrollo local)
SUPABASE_URL=https://xxxx.supabase.co
# Clave pública (publishable_key, antes anon_key): segura para exponer en cliente/frontend.
SUPABASE_PUBLISHABLE_KEY=xxxx
# Clave secreta (secret_key, antes service_role_key): privilegios elevados, solo para uso en backend.
SUPABASE_SECRET_KEY=xxxx

# PostgreSQL local (usado por docker-compose)
POSTGRES_USER=reporteria
POSTGRES_PASSWORD=reporteria
POSTGRES_DB=reporteria
DATABASE_URL=postgresql+asyncpg://reporteria:reporteria@localhost:5432/reporteria
# Nota: en Docker Compose el host debe ser "postgres" (nombre del servicio), no "localhost".
# docker-compose.yml sobreescribe este valor automáticamente.

# Google Cloud — proyecto y credenciales
# GOOGLE_CLOUD_SERVICE_ACCOUNT_KEY_CONTENT: JSON de la service account codificado en base64.
# Para codificar: base64 -i service-account.json | tr -d '\n'
GOOGLE_CLOUD_SERVICE_ACCOUNT_KEY_CONTENT=""
GOOGLE_CLOUD_PROJECT=proyecto-arqui-g6

# Google Cloud Pub/Sub — suscripciones exclusivas del Grupo 7
# Formato: projects/<proyecto>/subscriptions/<subscription-id>
PUBSUB_SUBSCRIPTION_ORDER_CREATED=projects/proyecto-arqui-g6/subscriptions/xxxx
PUBSUB_SUBSCRIPTION_PAYMENT_APPROVED=projects/proyecto-arqui-g6/subscriptions/xxxx
PUBSUB_SUBSCRIPTION_INVENTORY_SHORTAGE=projects/proyecto-arqui-g6/subscriptions/xxxx
PUBSUB_SUBSCRIPTION_SHIPMENT_DELIVERED=projects/proyecto-arqui-g6/subscriptions/g7-registro-sub

# Mocks — pon true para activar el middleware de mock de status HTTP
USE_MOCKS=false
