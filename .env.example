# App
APP_ENV=development
APP_PORT=8070

# Supabase (producción — dejar en blanco para desarrollo local)
SUPABASE_URL=https://xxxx.supabase.co
# Clave pública (publishable_key, antes anon_key): segura para exponer en cliente/frontend.
SUPABASE_PUBLISHABLE_KEY=xxxx
# Clave secreta (secret_key, antes service_role_key): privilegios elevados, solo para uso en backend.
SUPABASE_SECRET_KEY=xxxx

# PostgreSQL local (usado por docker-compose)
POSTGRES_USER=reporteria
POSTGRES_PASSWORD=reporteria
POSTGRES_DB=reporteria
DATABASE_URL=postgresql+asyncpg://reporteria:reporteria@localhost:5432/reporteria
# Nota: en Docker Compose el host debe ser "postgres" (nombre del servicio), no "localhost".
# docker-compose.yml sobreescribe este valor automáticamente.

# Google Cloud Pub/Sub — credenciales por grupo upstream.
# Cada tipo de evento lo publica un grupo distinto, con su propio proyecto GCP
# y su propia service account. Los subscription paths van hardcodeados en
# app/workers/pubsub_consumer.py (_EVENT_SOURCES), no como variables de entorno.
# JSON de la service account codificado en base64. Para codificar:
# base64 -i service-account.json | tr -d '\n'
G4_GOOGLE_CLOUD_SERVICE_ACCOUNT_KEY_CONTENT=""  # Grupo 4 — Inventario
G5_GOOGLE_CLOUD_SERVICE_ACCOUNT_KEY_CONTENT=""  # Grupo 5 — Pedidos
G6_GOOGLE_CLOUD_SERVICE_ACCOUNT_KEY_CONTENT=""  # Grupo 6 — Despacho
G8_GOOGLE_CLOUD_SERVICE_ACCOUNT_KEY_CONTENT=""  # Grupo 8 — Pagos

# Mocks — pon true para activar el middleware de mock de status HTTP
USE_MOCKS=false
